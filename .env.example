# ============================================================
# PatentIQ — Sample Environment Variables
# ============================================================
# This file is a template only. Do not store real secrets here.

# --- Application ---
# Set APP_ENV=production for deployment. Use development only for local testing.
APP_ENV=production
DEBUG=false

# --- Database (Neon PostgreSQL) ---
# Example: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/patentiq
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# --- Auth (Clerk) ---
# IMPORTANT: Replace with your production Clerk instance values
# Development keys (clerk.accounts.dev) have strict limits and should not be used in production
# Production keys use clerk.com domain

# Backend API Clerk configuration
CLERK_SECRET_KEY=sk_live_...  # Get from Clerk dashboard > API Keys
CLERK_PUBLISHABLE_KEY=pk_live_...  # Get from Clerk dashboard > API Keys
CLERK_JWKS_URL=https://your-domain.clerk.com/.well-known/jwks.json
CLERK_ISSUER=https://your-domain.clerk.com

# Next.js Clerk env vars (prefix with NEXT_PUBLIC_ for client access)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...  # Same as CLERK_PUBLISHABLE_KEY above
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- AI / Embeddings ---
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-law-2
VOYAGE_EMBEDDING_DIM=1024

# --- LLM ---
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash

# --- Storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=patentiq-docs
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=

# --- External Services ---
EPO_CLIENT_ID=
EPO_CLIENT_SECRET=

# --- Monitoring ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Analytics ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# --- Background Jobs / Cache ---
REDIS_URL=
CACHE_TTL_HOURS=48
WORKER_CONCURRENCY=4

# --- Network / API ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
NEXT_PUBLIC_API_URL=http://localhost:8000
