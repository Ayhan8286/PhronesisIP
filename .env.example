# ============================================================
# PatentIQ — Environment Variables Template
# Copy to .env and fill in your values
# ============================================================

# --- Application ---
APP_ENV=development
DEBUG=true

# --- Database (Neon PostgreSQL) ---
# Get from https://console.neon.tech → Connection Details
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.region.aws.neon.tech/patentiq?sslmode=require
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# --- Auth (Clerk) ---
# Get from https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-domain.clerk.accounts.dev

# Next.js Clerk env vars (prefix with NEXT_PUBLIC_ for client)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- AI / Embeddings ---
# Voyage AI: Get from https://dash.voyageai.com → API Keys
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-law-2
VOYAGE_EMBEDDING_DIM=1024

# --- LLM ---
# Gemini (free dev): Get from https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# Claude (production): Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Which LLM to use: "gemini" (free) or "claude" (production)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash

# --- Storage (Cloudflare R2) ---
# Get from https://dash.cloudflare.com → R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=patentiq-docs
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://docs.yourdomain.com

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# --- Background Jobs ---
WORKER_CONCURRENCY=4

# --- FastAPI Backend URL (used by Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
