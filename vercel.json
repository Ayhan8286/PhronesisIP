{
  "version": 2,
  "builds": [
    {
      "src": "apps/web/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "apps/api/index.py",
      "use": "@vercel/python",
      "config": { "runtime": "python3.12" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/apps/api/index.py"
    },
    {
      "source": "/api/inngest",
      "destination": "/apps/api/index.py"
    }
  ]
}
