{
  "version": 2,
  "builds": [
    {
      "src": "apps/web/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "apps/api/index.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/inngest",
      "destination": "apps/api/index.py"
    },
    {
      "source": "/api/v1/(.*)",
      "destination": "apps/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "apps/web/$1"
    }
  ]
}
